generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  refreshTokenHash String?
  dailyTargetNet   Float?
  workDaysPerWeek  Int?
  hasWeeklyPlan    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  days             Day[]
  serviceVisits    ServiceVisit[]
}

model Day {
  id        String   @id @default(cuid())
  userId    String
  date      String
  note      String?
  mileageKm Int?
  engineHours Float?
  incomeTotal Int @default(0)
  tripsCount  Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelings    Fueling[]
  washes      Wash[]
  snacks      Snack[]
  others      Other[]

  @@unique([userId, date])
}

model Fueling {
  id           String   @id @default(cuid())
  dayId        String
  costTotal    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Wash {
  id        String   @id @default(cuid())
  dayId     String
  costTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Snack {
  id        String   @id @default(cuid())
  dayId     String
  costTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Other {
  id        String   @id @default(cuid())
  dayId     String
  costTotal Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model ServiceVisit {
  id         String        @id @default(cuid())
  userId     String
  date       String
  mileageKm  Int
  workCost   Int
  totalCost  Int
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parts      ServicePart[]

  @@index([userId, date])
}

model ServicePart {
  id             String       @id @default(cuid())
  serviceVisitId String
  position       Int
  name           String
  isOriginal     Boolean
  unitCost       Int
  quantity       Int
  totalCost      Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  serviceVisit   ServiceVisit @relation(fields: [serviceVisitId], references: [id], onDelete: Cascade)

  @@index([serviceVisitId, position])
}

