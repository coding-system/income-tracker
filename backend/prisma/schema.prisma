generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  refreshTokenHash String?
  dailyTargetNet   Float?
  workDaysPerWeek  Int?
  hasWeeklyPlan    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  days             Day[]
}

model Day {
  id        String   @id @default(cuid())
  userId    String
  date      String
  note      String?
  mileageKm Int?
  engineHours Float?
  incomeTotal Float @default(0)
  tripsCount  Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelings    Fueling[]
  washes      Wash[]
  snacks      Snack[]

  @@unique([userId, date])
}

model Fueling {
  id           String   @id @default(cuid())
  dayId        String
  costTotal    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Wash {
  id        String   @id @default(cuid())
  dayId     String
  costTotal Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Snack {
  id        String   @id @default(cuid())
  dayId     String
  costTotal Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

